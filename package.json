    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^22.1.0",
    "sass": "^1.71.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vitest": "^3.2.2",
    "vue-tsc": "^2.0.6"
  }
}
